# Notion API Configuration
NOTION_TOKEN=your_notion_integration_token_here

# Main database — used for both the visual log cards and site copy rows
NOTION_DATABASE_ID=your_notion_database_id_here

# Optional: set this if you want site copy in a separate database.
# If not set, getContent() uses NOTION_DATABASE_ID as the fallback.
# NOTION_CONTENT_DATABASE_ID=your_separate_content_database_id_here