---
// Visual Log section with filtering and layout toggle
// Reusable across home and visual-log pages
import type { Section } from "../lib/sections";
import Card from "./ui/Card.astro";
import FilterPanel from "./FilterPanel.astro";

interface Props {
  sections: Section[];
  showFilter?: boolean;
  stickyFilter?: boolean;
  defaultFilter?: "selected" | "all";
  showAllButton?: boolean;
}

const { 
  sections, 
  showFilter = true, 
  stickyFilter = false,
  defaultFilter = "selected",
  showAllButton = false
} = Astro.props;

// Extract unique tags from all sections
const tags = Array.from(
  new Set(sections.flatMap((section) => section.tags))
).sort((a, b) => a.localeCompare(b));
---

<div class="relative bg-muted" id="visual-log-section">

  {showFilter && (
    <div class="mx-auto w-full max-w-screen-xl px-6 pb-10 pt-16 md:px-10">
      <h2 class="text-3xl font-semibold md:text-4xl">Visual Log</h2>
      <p class="mt-3 max-w-2xl text-base leading-relaxed text-muted-foreground md:text-lg">
        A running archive of design work, visual experiments, and things I find worth documenting — UI explorations, photography, motion, and craft.
      </p>
    </div>
  )}

  {showFilter && <FilterPanel tags={tags} isSticky={stickyFilter} />}
  
  <div class="section-shell py-12">
    <div
      id="visual-log-grid"
      data-layout="grid"
      class="transition-all duration-300"
    >
      {sections.map((section) => (
        <Card
          id={section.id}
          title={section.title}
          content={section.content}
          tags={section.tags}
          link={section.link}
          media={section.media}
          embedUrl={section.embedUrl}
          embedType={section.embedType}
          visibility={section.visibility}
          bodyContent={section.bodyContent}
        />
      ))}
    </div>
  </div>
  
  {showAllButton && (
    <div class="border-t border-border/50 bg-muted py-8">
      <div class="section-shell flex justify-center">
        <a
          href="/visual-log"
          class="inline-flex items-center gap-2 rounded-lg border border-accent bg-accent px-6 py-3 text-sm font-medium text-accent-foreground transition hover:bg-accent/90"
        >
          All projects →
        </a>
      </div>
    </div>
  )}
</div>

<script define:vars={{ defaultFilter }}>
  const visualLogGrid = document.getElementById("visual-log-grid");
  const cards = Array.from(document.querySelectorAll("[data-section]"));
  const filterButtons = Array.from(
    document.querySelectorAll("button[data-filter], button[data-tag]")
  );
  const layoutButtons = Array.from(
    document.querySelectorAll("button[data-layout-toggle]")
  );

  // Expand / collapse state
  const filterTagsContainer = document.getElementById("filter-tags-container");
  const filterExpandToggle = document.getElementById("filter-expand-toggle");
  const activeFilterChip = document.getElementById("active-filter-chip");
  const activeFilterLabel = document.getElementById("active-filter-label");
  const COLLAPSED_HEIGHT = "2.25rem";
  let isExpanded = false;

  // --- Collapse / expand helpers ---

  function collapseFilters() {
    if (!filterTagsContainer) return;
    filterTagsContainer.style.maxHeight = COLLAPSED_HEIGHT;
    if (filterExpandToggle) filterExpandToggle.textContent = "Show more";
    isExpanded = false;
    updateActiveChip();
  }

  function expandFilters() {
    if (!filterTagsContainer) return;
    filterTagsContainer.style.maxHeight = filterTagsContainer.scrollHeight + "px";
    if (filterExpandToggle) filterExpandToggle.textContent = "Show less";
    isExpanded = true;
    if (activeFilterChip) activeFilterChip.style.display = "none";
  }

  // Show expand toggle only if filters overflow to a second row
  function checkIfExpandNeeded() {
    if (!filterButtons.length || !filterExpandToggle) return;
    const firstRect = filterButtons[0].getBoundingClientRect();
    const hasOverflow = filterButtons.some((btn) => {
      return btn.getBoundingClientRect().top > firstRect.top + 8;
    });
    filterExpandToggle.style.display = hasOverflow ? "inline" : "none";
  }

  // A2: check whether the active button is visually hidden in the collapsed row
  function isButtonHiddenWhenCollapsed(button) {
    if (!filterButtons.length) return false;
    const firstRect = filterButtons[0].getBoundingClientRect();
    return button.getBoundingClientRect().top > firstRect.top + 8;
  }

  function updateActiveChip() {
    if (!activeFilterChip || !activeFilterLabel) return;
    const activeButton = filterButtons.find(
      (btn) => btn.getAttribute("data-active") === "true"
    );
    if (!isExpanded && activeButton && isButtonHiddenWhenCollapsed(activeButton)) {
      activeFilterChip.style.display = "flex";
      activeFilterLabel.textContent = activeButton.textContent.trim();
    } else {
      activeFilterChip.style.display = "none";
    }
  }

  // --- Filter / layout state ---

  const setActiveFilter = (button) => {
    filterButtons.forEach((btn) => {
      btn.setAttribute("data-active", btn === button ? "true" : "false");
    });
    if (isExpanded) {
      collapseFilters();
    } else {
      updateActiveChip();
    }
  };

  const setActiveLayout = (button) => {
    layoutButtons.forEach((btn) => {
      btn.setAttribute("data-active", btn === button ? "true" : "false");
    });
  };

  const showSelectedWorks = () => {
    cards.forEach((card) => {
      const visibility = card.getAttribute("data-visibility") || "";
      card.classList.toggle("hidden", visibility !== "selected works");
    });
  };

  const showAll = () => {
    cards.forEach((card) => card.classList.remove("hidden"));
  };

  const showByTag = (tag) => {
    cards.forEach((card) => {
      const tags = (card.getAttribute("data-tags") || "").split("|").filter(Boolean);
      card.classList.toggle("hidden", !tags.includes(tag));
    });
  };

  // --- Event listeners ---

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const filter = button.getAttribute("data-filter");
      const tag = button.getAttribute("data-tag");

      if (filter === "selected") { setActiveFilter(button); showSelectedWorks(); return; }
      if (filter === "all")      { setActiveFilter(button); showAll();           return; }
      if (tag)                   { setActiveFilter(button); showByTag(tag);      return; }
    });
  });

  layoutButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const layout = button.getAttribute("data-layout-toggle");
      if (layout && visualLogGrid) {
        visualLogGrid.setAttribute("data-layout", layout);
        setActiveLayout(button);
      }
    });
  });

  if (filterExpandToggle) {
    filterExpandToggle.addEventListener("click", () => {
      isExpanded ? collapseFilters() : expandFilters();
    });
  }

  // Chip click: clear filter → show all
  if (activeFilterChip) {
    activeFilterChip.addEventListener("click", () => {
      const allButton = document.querySelector('button[data-filter="all"]');
      if (allButton) { setActiveFilter(allButton); showAll(); }
      activeFilterChip.style.display = "none";
    });
  }

  // --- Initialise ---

  const defaultFilterButton = document.querySelector(
    `button[data-filter="${defaultFilter}"]`
  );
  if (defaultFilterButton) {
    filterButtons.forEach((btn) => {
      btn.setAttribute("data-active", btn === defaultFilterButton ? "true" : "false");
    });
    if (defaultFilter === "selected") showSelectedWorks();
    else if (defaultFilter === "all") showAll();
  }

  // After first paint: check overflow and chip state
  requestAnimationFrame(() => {
    checkIfExpandNeeded();
    updateActiveChip();
  });

  // Re-check on resize (viewport width affects row count)
  window.addEventListener("resize", () => {
    checkIfExpandNeeded();
    if (!isExpanded) updateActiveChip();
  });
</script>
