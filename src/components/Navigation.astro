---
// Top navigation - minimal three-link navigation
// Mobile responsive with reduced height
import ThemeToggle from "./ThemeToggle.astro";
---

<nav class="sticky top-0 z-20 border-b border-border/60 bg-bg/80 backdrop-blur">
  <div class="mx-auto flex h-12 max-w-screen-xl items-center justify-between gap-6 px-6">
    <a 
      class="text-sm font-semibold transition-colors hover:text-accent" 
      href="/"
      id="nav-home"
    >
      Olli Kilpi
    </a>
    <div class="flex items-center gap-6">
      <nav class="flex items-center gap-6 text-sm text-muted-foreground">
        <a 
          class="transition-colors hover:text-foreground" 
          href="/visual-log"
        >
          Visual Log
        </a>
        <a 
          class="transition-colors hover:text-foreground" 
          href="/my-journey"
        >
          My journey
        </a>
      </nav>
      <ThemeToggle />
    </div>
  </div>
</nav>
