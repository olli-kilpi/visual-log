---
// Simple video player
interface Props {
  src: string;
  autoplay?: boolean;
  loop?: boolean;
}

const { src, autoplay = false, loop = true } = Astro.props;
---

<video
  class="h-full w-full object-contain"
  src={src}
  controls
  autoplay={autoplay}
  loop={loop}
  muted={autoplay}
  playsinline
>
  Your browser does not support the video tag.
</video>
