---
// Card component - reusable for blog items in grid or list layout
// Uses token-based styling and responds to data-layout attribute
import EmbedPlayer from "../EmbedPlayer.astro";
import { detectEmbedType } from "../../lib/embedUtils";

interface Props {
  id: string;
  title: string;
  content: string;
  tags?: string[];
  link?: string;
  media?: string;
  embedUrl?: string;
  embedType?: string;
  visibility?: string;
}

const { 
  id, 
  title, 
  content, 
  tags = [], 
  link, 
  media, 
  embedUrl,
  embedType,
  visibility = "" 
} = Astro.props;

// Prioritize embedUrl, but also check if media is an embed type (like .riv files)
const displaySource = embedUrl || media;
const isEmbed = !!embedUrl || (media ? detectEmbedType(media) !== 'none' && detectEmbedType(media) !== 'iframe' : false);
const mediaEmbedType = media && !embedUrl ? detectEmbedType(media) : undefined;
---

<article
  class="card group relative flex overflow-hidden rounded-lg border border-border/60 bg-card shadow-sm transition-shadow hover:shadow-md"
  data-section
  data-visibility={visibility.toLowerCase()}
  data-tags={tags.map((tag) => tag.toLowerCase()).join("|")}
  id={id}
>
  <!-- Media Section - always rendered for consistent layout -->
  <div class="card-media w-full overflow-hidden">
    {displaySource ? (
      isEmbed ? (
        <EmbedPlayer src={embedUrl || media!} type={embedType || mediaEmbedType} />
      ) : (
        <div class="aspect-video w-full overflow-hidden bg-muted">
          <img
            class="h-full w-full object-cover transition-transform group-hover:scale-105"
            src={media}
            alt={`${title} media`}
            loading="lazy"
          />
        </div>
      )
    ) : (
      <div class="aspect-video w-full overflow-hidden bg-muted flex items-center justify-center">
        <svg class="h-16 w-16 text-muted-foreground/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}
  </div>
  
  <!-- Content Section -->
  <div class="card-content flex flex-1 flex-col gap-3 p-6">
    <h2 class="text-xl font-semibold leading-tight md:text-2xl">{title}</h2>
    <p class="flex-1 text-sm leading-relaxed text-muted-foreground md:text-base">{content}</p>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="rounded-full border border-border/60 px-2.5 py-0.5 text-xs text-muted-foreground">
            {tag}
          </span>
        ))}
      </div>
    )}
    {link && (
      <a
        class="inline-flex items-center text-sm font-medium text-accent hover:underline"
        href={link}
        target="_blank"
        rel="noreferrer"
      >
        View project →
      </a>
    )}
  </div>
</article>
