---
import EmbedPlayer from "../EmbedPlayer.astro";
import Button from "./Button.astro";
import { detectEmbedType } from "../../lib/embedUtils";

interface Props {
  id: string;
  title: string;
  content: string;
  tags?: string[];
  link?: string;
  media?: string;
  embedUrl?: string;
  embedType?: string;
  bodyContent?: string;
}

const {
  id,
  title,
  content,
  tags = [],
  link,
  media,
  embedUrl,
  embedType,
  bodyContent,
} = Astro.props;

const displaySource = embedUrl || media;
const isEmbed =
  !!embedUrl ||
  (media
    ? detectEmbedType(media) !== "none" && detectEmbedType(media) !== "iframe"
    : false);
const mediaEmbedType =
  media && !embedUrl ? detectEmbedType(media) : undefined;
---

<div class="flex h-full flex-col lg:flex-row">
  <!-- Media panel -->
  <div class="card-modal-media w-full shrink-0 bg-muted lg:w-[55%]">
    {displaySource ? (
      isEmbed ? (
        <div class="flex h-full items-center justify-center p-4 lg:p-6">
          <EmbedPlayer
            src={embedUrl || media!}
            type={embedType || mediaEmbedType}
          />
        </div>
      ) : (
        <div class="flex h-full items-center justify-center">
          <img
            class="h-full w-full object-cover"
            src={media}
            alt={`${title} media`}
            loading="lazy"
          />
        </div>
      )
    ) : (
      <div class="flex aspect-video items-center justify-center lg:aspect-auto lg:h-full">
        <svg
          class="h-16 w-16 text-muted-foreground/30"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
          />
        </svg>
      </div>
    )}
  </div>

  <!-- Content panel -->
  <div class="flex flex-1 flex-col overflow-y-auto p-6 lg:p-8">
    <h2 id={`${id}-title`} class="text-2xl font-semibold leading-tight lg:text-3xl">
      {title}
    </h2>

    <p class="mt-3 text-sm leading-relaxed text-muted-foreground lg:text-base">
      {content}
    </p>

    {tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="rounded-full border border-border/60 px-2.5 py-0.5 text-xs text-muted-foreground">
            {tag}
          </span>
        ))}
      </div>
    )}

    {bodyContent && (
      <div
        class="card-modal-body mt-6 border-t border-border/40 pt-6"
        set:html={bodyContent}
      />
    )}

    <div class="mt-auto pt-6">
      {link && (
        <Button as="a" href={link} variant="default" size="md">
          View project →
        </Button>
      )}
    </div>
  </div>
</div>
