---
// Hero section — text content fetched from Notion CMS
import { getContent } from "../lib/content";

const content = await getContent();
---

<section
  id="hero"
  class="sticky top-0 z-0 flex h-screen flex-col justify-center overflow-hidden border-b border-border/50 bg-muted"
>
  <div class="section-shell">
    <div class="max-w-3xl space-y-6">
      <p class="text-sm uppercase tracking-[0.2em] text-muted-foreground">
        {content["hero.role"]}
      </p>
      <h1 class="text-5xl font-semibold leading-tight md:text-6xl lg:text-7xl">
        {content["hero.title"]}
      </h1>
      <p class="text-lg leading-relaxed text-muted-foreground md:text-xl">
        {content["hero.body"]}
      </p>
    </div>
  </div>
</section>
