---
// Visual Log page - Full view with footer, sorted by date
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogSection from "../components/BlogSection.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { getSections, sortSectionsByDate } from "../lib/sections";

const sections = sortSectionsByDate(await getSections());
---

<BaseLayout title="Visual Log - Olli Kilpi">
  <Navigation />
  <main class="relative bg-muted">
    <BlogSection 
      sections={sections} 
      showFilter={true} 
      stickyFilter={true}
      defaultFilter="all"
      showAllButton={false}
    />
  </main>
  <Footer />
</BaseLayout>
