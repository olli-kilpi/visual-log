---
// Design System reference page — visual documentation of all tokens and components
import BaseLayout from "../layouts/BaseLayout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Design System — Olli Kilpi"
  description="Visual reference for the design tokens and components used across this site."
>
  <Navigation />
  <main class="bg-bg min-h-screen">
    <div class="section-shell space-y-24">

      <!-- Page Header -->
      <header class="space-y-4 border-b border-border/50 pb-12">
        <p class="text-xs uppercase tracking-[0.2em] text-muted-foreground">Internal Reference</p>
        <h1 class="text-4xl font-semibold md:text-5xl">Design System</h1>
        <p class="max-w-xl text-lg text-muted-foreground">
          A visual reference for the tokens and components that make up this site.
          When <code class="rounded-sm bg-muted px-1.5 py-0.5 font-mono text-sm">tokens.css</code> changes, everything here reflects it automatically.
        </p>
      </header>

      <!-- ==============================
           COLORS
           ============================== -->
      <section class="space-y-8">
        <div class="space-y-1">
          <h2 class="text-2xl font-semibold">Colors</h2>
          <p class="text-sm text-muted-foreground">11 semantic tokens. All adapt in dark mode.</p>
        </div>

        <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
          <!-- Backgrounds -->
          <div class="space-y-2">
            <p class="text-xs uppercase tracking-widest text-muted-foreground">Backgrounds</p>

            <div class="flex items-center gap-4 rounded-md border border-border/60 p-3">
              <div class="h-10 w-10 flex-shrink-0 rounded-md border border-border/60 bg-bg shadow-sm"></div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium">Background</p>
                <p class="font-mono text-xs text-muted-foreground">--color-bg · bg-bg</p>
              </div>
              <p class="hidden font-mono text-xs text-muted-foreground sm:block">#fcfcfc</p>
            </div>

            <div class="flex items-center gap-4 rounded-md border border-border/60 p-3">
              <div class="h-10 w-10 flex-shrink-0 rounded-md border border-border/60 bg-muted shadow-sm"></div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium">Muted</p>
                <p class="font-mono text-xs text-muted-foreground">--color-muted · bg-muted</p>
              </div>
              <p class="hidden font-mono text-xs text-muted-foreground sm:block">#f5f5f5</p>
            </div>

            <div class="flex items-center gap-4 rounded-md border border-border/60 p-3">
              <div class="h-10 w-10 flex-shrink-0 rounded-md border border-border/60 bg-card shadow-sm"></div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium">Card</p>
                <p class="font-mono text-xs text-muted-foreground">--color-card · bg-card</p>
              </div>
              <p class="hidden font-mono text-xs text-muted-foreground sm:block">#ffffff</p>
            </div>

            <div class="flex items-center gap-4 rounded-md border border-border/60 p-3">
              <div class="h-10 w-10 flex-shrink-0 rounded-md border border-border/60 shadow-sm" style="background-color: var(--color-footer-bg);"></div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium">Footer Background</p>
                <p class="font-mono text-xs text-muted-foreground">--color-footer-bg</p>
              </div>
              <p class="hidden font-mono text-xs text-muted-foreground sm:block">#404040</p>
            </div>

            <div class="flex items-center gap-4 rounded-md border border-border/60 p-3">
              <div class="h-10 w-10 flex-shrink-0 rounded-md border border-border/60 shadow-sm" style="background-color: var(--color-footer-fg);"></div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium">Footer Foreground</p>
                <p class="font-mono text-xs text-muted-foreground">--color-footer-fg</p>
              </div>
              <p class="hidden font-mono text-xs text-muted-foreground sm:block">#fafafa</p>
            </div>
          </div>

          <!-- Text & UI -->
          <div class="space-y-2">
            <p class="text-xs uppercase tracking-widest text-muted-foreground">Text & UI</p>

            <div class="flex items-center gap-4 rounded-md border border-border/60 p-3">
              <div class="h-10 w-10 flex-shrink-0 rounded-md border border-border/60 shadow-sm" style="background-color: var(--color-fg);"></div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium">Foreground</p>
                <p class="font-mono text-xs text-muted-foreground">--color-fg · text-foreground</p>
              </div>
              <p class="hidden font-mono text-xs text-muted-foreground sm:block">#1c1c1c</p>
            </div>

            <div class="flex items-center gap-4 rounded-md border border-border/60 p-3">
              <div class="h-10 w-10 flex-shrink-0 rounded-md border border-border/60 shadow-sm" style="background-color: var(--color-muted-fg);"></div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium">Muted Foreground</p>
                <p class="font-mono text-xs text-muted-foreground">--color-muted-fg · text-muted-foreground</p>
              </div>
              <p class="hidden font-mono text-xs text-muted-foreground sm:block">#787878</p>
            </div>

            <div class="flex items-center gap-4 rounded-md border border-border/60 p-3">
              <div class="h-10 w-10 flex-shrink-0 rounded-md border border-border/60 bg-accent shadow-sm"></div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium">Accent</p>
                <p class="font-mono text-xs text-muted-foreground">--color-accent · bg-accent</p>
              </div>
              <p class="hidden font-mono text-xs text-muted-foreground sm:block">#333333</p>
            </div>

            <div class="flex items-center gap-4 rounded-md border border-border/60 p-3">
              <div class="h-10 w-10 flex-shrink-0 rounded-md border-2 border-border bg-bg shadow-sm"></div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium">Border</p>
                <p class="font-mono text-xs text-muted-foreground">--color-border · border-border</p>
              </div>
              <p class="hidden font-mono text-xs text-muted-foreground sm:block">#e0e0e0</p>
            </div>

            <div class="flex items-center gap-4 rounded-md border border-border/60 p-3">
              <div class="h-10 w-10 flex-shrink-0 rounded-md bg-accent shadow-sm flex items-center justify-center">
                <span class="text-xs font-medium text-accent-foreground">Aa</span>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium">Accent Foreground</p>
                <p class="font-mono text-xs text-muted-foreground">--color-accent-fg · text-accent-foreground</p>
              </div>
              <p class="hidden font-mono text-xs text-muted-foreground sm:block">#ffffff</p>
            </div>

            <div class="flex items-center gap-4 rounded-md border border-border/60 p-3">
              <div class="h-10 w-10 flex-shrink-0 rounded-md bg-bg shadow-sm ring-2 ring-ring"></div>
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium">Ring (Focus)</p>
                <p class="font-mono text-xs text-muted-foreground">--color-ring · ring-ring</p>
              </div>
              <p class="hidden font-mono text-xs text-muted-foreground sm:block">#333333</p>
            </div>
          </div>
        </div>

        <p class="rounded-md border border-border/60 px-4 py-3 text-xs text-muted-foreground">
          All tokens above adapt in dark mode. Toggle via the theme switcher in the footer to preview.
        </p>
      </section>

      <!-- ==============================
           TYPOGRAPHY
           ============================== -->
      <section class="space-y-8">
        <div class="space-y-1">
          <h2 class="text-2xl font-semibold">Typography</h2>
          <p class="text-sm text-muted-foreground">8 token steps (xs–4xl) from 12px to 36px, each with a calibrated line height. Display sizes (5xl–7xl) use Tailwind defaults.</p>
        </div>

        <div class="divide-y divide-border/40">
          <div class="flex items-baseline gap-6 py-4">
            <span class="w-20 flex-shrink-0 font-mono text-xs text-muted-foreground">text-xs</span>
            <span class="text-xs">The quick brown fox jumps over the lazy dog</span>
            <span class="ml-auto hidden font-mono text-xs text-muted-foreground sm:block">12px / 1.1rem</span>
          </div>
          <div class="flex items-baseline gap-6 py-4">
            <span class="w-20 flex-shrink-0 font-mono text-xs text-muted-foreground">text-sm</span>
            <span class="text-sm">The quick brown fox jumps over the lazy dog</span>
            <span class="ml-auto hidden font-mono text-xs text-muted-foreground sm:block">14px / 1.35rem</span>
          </div>
          <div class="flex items-baseline gap-6 py-4">
            <span class="w-20 flex-shrink-0 font-mono text-xs text-muted-foreground">text-base</span>
            <span class="text-base">The quick brown fox jumps over the lazy dog</span>
            <span class="ml-auto hidden font-mono text-xs text-muted-foreground sm:block">16px / 1.6rem</span>
          </div>
          <div class="flex items-baseline gap-6 py-4">
            <span class="w-20 flex-shrink-0 font-mono text-xs text-muted-foreground">text-lg</span>
            <span class="text-lg">The quick brown fox jumps over the lazy dog</span>
            <span class="ml-auto hidden font-mono text-xs text-muted-foreground sm:block">18px / 1.75rem</span>
          </div>
          <div class="flex items-baseline gap-6 py-4">
            <span class="w-20 flex-shrink-0 font-mono text-xs text-muted-foreground">text-xl</span>
            <span class="text-xl">The quick brown fox jumps</span>
            <span class="ml-auto hidden font-mono text-xs text-muted-foreground sm:block">20px / 1.85rem</span>
          </div>
          <div class="flex items-baseline gap-6 py-4">
            <span class="w-20 flex-shrink-0 font-mono text-xs text-muted-foreground">text-2xl</span>
            <span class="text-2xl">The quick brown fox jumps</span>
            <span class="ml-auto hidden font-mono text-xs text-muted-foreground sm:block">24px / 2rem</span>
          </div>
          <div class="flex items-baseline gap-6 py-4">
            <span class="w-20 flex-shrink-0 font-mono text-xs text-muted-foreground">text-3xl</span>
            <span class="text-3xl">The quick brown fox</span>
            <span class="ml-auto hidden font-mono text-xs text-muted-foreground sm:block">30px / 2.4rem</span>
          </div>
          <div class="flex items-baseline gap-6 py-4">
            <span class="w-20 flex-shrink-0 font-mono text-xs text-muted-foreground">text-4xl</span>
            <span class="text-4xl">The quick brown fox</span>
            <span class="ml-auto hidden font-mono text-xs text-muted-foreground sm:block">36px / 2.8rem</span>
          </div>
          <div class="flex items-baseline gap-6 py-4">
            <span class="w-20 flex-shrink-0 font-mono text-xs text-muted-foreground">text-5xl</span>
            <span class="text-5xl">Display</span>
            <span class="ml-auto hidden font-mono text-xs text-muted-foreground sm:block">48px · Tailwind default</span>
          </div>
          <div class="flex items-baseline gap-6 py-4">
            <span class="w-20 flex-shrink-0 font-mono text-xs text-muted-foreground">text-6xl</span>
            <span class="text-6xl">Display</span>
            <span class="ml-auto hidden font-mono text-xs text-muted-foreground sm:block">60px · Tailwind default</span>
          </div>
          <div class="flex items-baseline gap-6 py-4">
            <span class="w-20 flex-shrink-0 font-mono text-xs text-muted-foreground">text-7xl</span>
            <span class="text-7xl">Display</span>
            <span class="ml-auto hidden font-mono text-xs text-muted-foreground sm:block">72px · Tailwind default</span>
          </div>
        </div>

        <!-- Font families -->
        <div class="grid grid-cols-1 gap-4 pt-4 md:grid-cols-2">
          <div class="space-y-2 rounded-md border border-border/60 p-6">
            <p class="text-xs uppercase tracking-widest text-muted-foreground">Sans · --font-sans</p>
            <p class="font-sans text-2xl">Inter, SF Pro Text</p>
            <p class="font-sans text-sm text-muted-foreground">
              ABCDEFGHIJKLMNOPQRSTUVWXYZ<br />
              abcdefghijklmnopqrstuvwxyz<br />
              0123456789 !@#$%&
            </p>
          </div>
          <div class="space-y-2 rounded-md border border-border/60 p-6">
            <p class="text-xs uppercase tracking-widest text-muted-foreground">Mono · --font-mono</p>
            <p class="font-mono text-2xl">SF Mono, Menlo</p>
            <p class="font-mono text-sm text-muted-foreground">
              ABCDEFGHIJKLMNOPQRSTUVWXYZ<br />
              abcdefghijklmnopqrstuvwxyz<br />
              0123456789 !@#$%&
            </p>
          </div>
        </div>
      </section>

      <!-- ==============================
           SPACING
           ============================== -->
      <section class="space-y-8">
        <div class="space-y-1">
          <h2 class="text-2xl font-semibold">Spacing</h2>
          <p class="text-sm text-muted-foreground">4px base unit. 12 steps from 4px to 96px.</p>
        </div>

        <div class="space-y-3">
          <div class="flex items-center gap-6">
            <span class="w-28 flex-shrink-0 font-mono text-xs text-muted-foreground">--space-1</span>
            <div class="h-4 w-1 flex-shrink-0 rounded-sm bg-accent/40"></div>
            <span class="font-mono text-xs text-muted-foreground">4px / 0.25rem</span>
          </div>
          <div class="flex items-center gap-6">
            <span class="w-28 flex-shrink-0 font-mono text-xs text-muted-foreground">--space-2</span>
            <div class="h-4 w-2 flex-shrink-0 rounded-sm bg-accent/40"></div>
            <span class="font-mono text-xs text-muted-foreground">8px / 0.5rem</span>
          </div>
          <div class="flex items-center gap-6">
            <span class="w-28 flex-shrink-0 font-mono text-xs text-muted-foreground">--space-3</span>
            <div class="h-4 w-3 flex-shrink-0 rounded-sm bg-accent/40"></div>
            <span class="font-mono text-xs text-muted-foreground">12px / 0.75rem</span>
          </div>
          <div class="flex items-center gap-6">
            <span class="w-28 flex-shrink-0 font-mono text-xs text-muted-foreground">--space-4</span>
            <div class="h-4 w-4 flex-shrink-0 rounded-sm bg-accent/40"></div>
            <span class="font-mono text-xs text-muted-foreground">16px / 1rem</span>
          </div>
          <div class="flex items-center gap-6">
            <span class="w-28 flex-shrink-0 font-mono text-xs text-muted-foreground">--space-5</span>
            <div class="h-4 w-5 flex-shrink-0 rounded-sm bg-accent/40"></div>
            <span class="font-mono text-xs text-muted-foreground">20px / 1.25rem</span>
          </div>
          <div class="flex items-center gap-6">
            <span class="w-28 flex-shrink-0 font-mono text-xs text-muted-foreground">--space-6</span>
            <div class="h-4 w-6 flex-shrink-0 rounded-sm bg-accent/40"></div>
            <span class="font-mono text-xs text-muted-foreground">24px / 1.5rem</span>
          </div>
          <div class="flex items-center gap-6">
            <span class="w-28 flex-shrink-0 font-mono text-xs text-muted-foreground">--space-8</span>
            <div class="h-4 w-8 flex-shrink-0 rounded-sm bg-accent/40"></div>
            <span class="font-mono text-xs text-muted-foreground">32px / 2rem</span>
          </div>
          <div class="flex items-center gap-6">
            <span class="w-28 flex-shrink-0 font-mono text-xs text-muted-foreground">--space-10</span>
            <div class="h-4 w-10 flex-shrink-0 rounded-sm bg-accent/40"></div>
            <span class="font-mono text-xs text-muted-foreground">40px / 2.5rem</span>
          </div>
          <div class="flex items-center gap-6">
            <span class="w-28 flex-shrink-0 font-mono text-xs text-muted-foreground">--space-12</span>
            <div class="h-4 w-12 flex-shrink-0 rounded-sm bg-accent/40"></div>
            <span class="font-mono text-xs text-muted-foreground">48px / 3rem</span>
          </div>
          <div class="flex items-center gap-6">
            <span class="w-28 flex-shrink-0 font-mono text-xs text-muted-foreground">--space-16</span>
            <div class="h-4 w-16 flex-shrink-0 rounded-sm bg-accent/40"></div>
            <span class="font-mono text-xs text-muted-foreground">64px / 4rem</span>
          </div>
          <div class="flex items-center gap-6">
            <span class="w-28 flex-shrink-0 font-mono text-xs text-muted-foreground">--space-20</span>
            <div class="h-4 w-20 flex-shrink-0 rounded-sm bg-accent/40"></div>
            <span class="font-mono text-xs text-muted-foreground">80px / 5rem</span>
          </div>
          <div class="flex items-center gap-6">
            <span class="w-28 flex-shrink-0 font-mono text-xs text-muted-foreground">--space-24</span>
            <div class="h-4 w-24 flex-shrink-0 rounded-sm bg-accent/40"></div>
            <span class="font-mono text-xs text-muted-foreground">96px / 6rem</span>
          </div>
        </div>
      </section>

      <!-- ==============================
           BORDER RADIUS
           ============================== -->
      <section class="space-y-8">
        <div class="space-y-1">
          <h2 class="text-2xl font-semibold">Border Radius</h2>
          <p class="text-sm text-muted-foreground">4 token steps from 6px to 16px, plus <code class="rounded-sm bg-muted px-1.5 py-0.5 font-mono text-xs">rounded-full</code> for pills and badges.</p>
        </div>

        <div class="grid grid-cols-2 gap-6 md:grid-cols-5">
          <div class="space-y-3 text-center">
            <div class="mx-auto h-20 w-20 rounded-sm border-2 border-accent/30 bg-muted"></div>
            <div>
              <p class="text-sm font-medium">Small</p>
              <p class="font-mono text-xs text-muted-foreground">rounded-sm</p>
              <p class="mt-0.5 font-mono text-xs text-muted-foreground">6px</p>
            </div>
          </div>
          <div class="space-y-3 text-center">
            <div class="mx-auto h-20 w-20 rounded-md border-2 border-accent/30 bg-muted"></div>
            <div>
              <p class="text-sm font-medium">Medium</p>
              <p class="font-mono text-xs text-muted-foreground">rounded-md</p>
              <p class="mt-0.5 font-mono text-xs text-muted-foreground">8px</p>
            </div>
          </div>
          <div class="space-y-3 text-center">
            <div class="mx-auto h-20 w-20 rounded-lg border-2 border-accent/30 bg-muted"></div>
            <div>
              <p class="text-sm font-medium">Large</p>
              <p class="font-mono text-xs text-muted-foreground">rounded-lg</p>
              <p class="mt-0.5 font-mono text-xs text-muted-foreground">12px</p>
            </div>
          </div>
          <div class="space-y-3 text-center">
            <div class="mx-auto h-20 w-20 rounded-xl border-2 border-accent/30 bg-muted"></div>
            <div>
              <p class="text-sm font-medium">X-Large</p>
              <p class="font-mono text-xs text-muted-foreground">rounded-xl</p>
              <p class="mt-0.5 font-mono text-xs text-muted-foreground">16px</p>
            </div>
          </div>
          <div class="space-y-3 text-center">
            <div class="mx-auto h-20 w-20 rounded-full border-2 border-accent/30 bg-muted"></div>
            <div>
              <p class="text-sm font-medium">Full</p>
              <p class="font-mono text-xs text-muted-foreground">rounded-full</p>
              <p class="mt-0.5 font-mono text-xs text-muted-foreground">9999px</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ==============================
           SHADOWS
           ============================== -->
      <section class="space-y-8">
        <div class="space-y-1">
          <h2 class="text-2xl font-semibold">Shadows</h2>
          <p class="text-sm text-muted-foreground">3 elevation levels for depth and hierarchy.</p>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
          <div class="space-y-4">
            <div class="h-24 rounded-lg bg-card shadow-sm"></div>
            <div>
              <p class="text-sm font-medium">Small</p>
              <p class="font-mono text-xs text-muted-foreground">shadow-sm</p>
              <p class="mt-1 text-xs text-muted-foreground">Cards at rest, subtle lift</p>
            </div>
          </div>
          <div class="space-y-4">
            <div class="h-24 rounded-lg bg-card shadow-md"></div>
            <div>
              <p class="text-sm font-medium">Medium</p>
              <p class="font-mono text-xs text-muted-foreground">shadow-md</p>
              <p class="mt-1 text-xs text-muted-foreground">Hover states, dropdowns</p>
            </div>
          </div>
          <div class="space-y-4">
            <div class="h-24 rounded-lg bg-card shadow-lg"></div>
            <div>
              <p class="text-sm font-medium">Large</p>
              <p class="font-mono text-xs text-muted-foreground">shadow-lg</p>
              <p class="mt-1 text-xs text-muted-foreground">Modals, elevated panels</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ==============================
           LAYOUT VARIABLES
           ============================== -->
      <section class="space-y-8">
        <div class="space-y-1">
          <h2 class="text-2xl font-semibold">Layout Variables</h2>
          <p class="text-sm text-muted-foreground">Structural values defined in <code class="rounded-sm bg-muted px-1.5 py-0.5 font-mono text-xs">global.css</code> for cross-component layout coordination.</p>
        </div>

        <div class="space-y-3">
          <div class="flex items-center gap-4 rounded-md border border-border/60 p-3">
            <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-md border border-accent/20 bg-accent/10">
              <span class="font-mono text-xs text-accent">3rem</span>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium">Nav Height</p>
              <p class="font-mono text-xs text-muted-foreground">--nav-height · defined in :root</p>
            </div>
            <p class="hidden font-mono text-xs text-muted-foreground sm:block">3rem / 48px = h-12 = --space-12</p>
          </div>
        </div>

        <p class="rounded-md border border-border/60 px-4 py-3 text-xs text-muted-foreground">
          Used in Hero: <code class="rounded-sm bg-muted px-1.5 py-0.5 font-mono">height: calc(100dvh - var(--nav-height))</code>. Used in FilterPanel sticky offset: <code class="rounded-sm bg-muted px-1.5 py-0.5 font-mono">top-12</code>. Update both when nav height changes.
        </p>
      </section>

      <!-- ==============================
           COMPONENTS
           ============================== -->
      <section class="space-y-12">
        <div class="space-y-1">
          <h2 class="text-2xl font-semibold">Components</h2>
          <p class="text-sm text-muted-foreground">Reusable UI pieces built from the token system above.</p>
        </div>

        <!-- Button -->
        <div class="space-y-6">
          <h3 class="border-b border-border/50 pb-3 text-lg font-medium">Button</h3>
          <div class="space-y-4">
            <div class="flex flex-wrap items-center gap-4">
              <span class="w-24 font-mono text-xs text-muted-foreground">default</span>
              <button class="inline-flex h-9 items-center justify-center rounded-md bg-accent px-3 text-sm font-medium text-accent-foreground transition-colors hover:bg-accent/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">Small</button>
              <button class="inline-flex h-10 items-center justify-center rounded-md bg-accent px-4 text-sm font-medium text-accent-foreground transition-colors hover:bg-accent/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">Medium</button>
              <button class="inline-flex h-11 items-center justify-center rounded-md bg-accent px-6 text-sm font-medium text-accent-foreground transition-colors hover:bg-accent/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">Large</button>
            </div>
            <div class="flex flex-wrap items-center gap-4">
              <span class="w-24 font-mono text-xs text-muted-foreground">secondary</span>
              <button class="inline-flex h-9 items-center justify-center rounded-md bg-muted px-3 text-sm font-medium text-foreground transition-colors hover:bg-muted/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">Small</button>
              <button class="inline-flex h-10 items-center justify-center rounded-md bg-muted px-4 text-sm font-medium text-foreground transition-colors hover:bg-muted/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">Medium</button>
              <button class="inline-flex h-11 items-center justify-center rounded-md bg-muted px-6 text-sm font-medium text-foreground transition-colors hover:bg-muted/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">Large</button>
            </div>
            <div class="flex flex-wrap items-center gap-4">
              <span class="w-24 font-mono text-xs text-muted-foreground">outline</span>
              <button class="inline-flex h-9 items-center justify-center rounded-md border border-border bg-transparent px-3 text-sm font-medium transition-colors hover:bg-muted/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">Small</button>
              <button class="inline-flex h-10 items-center justify-center rounded-md border border-border bg-transparent px-4 text-sm font-medium transition-colors hover:bg-muted/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">Medium</button>
              <button class="inline-flex h-11 items-center justify-center rounded-md border border-border bg-transparent px-6 text-sm font-medium transition-colors hover:bg-muted/40 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">Large</button>
            </div>
          </div>
        </div>

        <!-- Tag / Badge -->
        <div class="space-y-6">
          <h3 class="border-b border-border/50 pb-3 text-lg font-medium">Tag / Badge</h3>
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full border border-border/60 px-2.5 py-0.5 text-xs text-muted-foreground">Research</span>
            <span class="rounded-full border border-border/60 px-2.5 py-0.5 text-xs text-muted-foreground">UI Systems</span>
            <span class="rounded-full border border-border/60 px-2.5 py-0.5 text-xs text-muted-foreground">Motion Design</span>
            <span class="rounded-full border border-border/60 px-2.5 py-0.5 text-xs text-muted-foreground">Frontend</span>
            <span class="rounded-full border border-border/60 px-2.5 py-0.5 text-xs text-muted-foreground">Strategy</span>
          </div>
        </div>

        <!-- Filter Button -->
        <div class="space-y-6">
          <h3 class="border-b border-border/50 pb-3 text-lg font-medium">Filter Button</h3>
          <div class="flex flex-wrap gap-2">
            <button class="rounded-full border border-border/60 px-3 py-1.5 text-xs text-muted-foreground transition hover:border-accent/40">All work</button>
            <button class="rounded-full border-transparent bg-accent px-3 py-1.5 text-xs text-accent-foreground transition">Selected works</button>
            <button class="rounded-full border border-border/60 px-3 py-1.5 text-xs text-muted-foreground transition hover:border-accent/40">Research</button>
            <button class="rounded-full border border-border/60 px-3 py-1.5 text-xs text-muted-foreground transition hover:border-accent/40">Motion</button>
          </div>
          <p class="text-xs text-muted-foreground">Active state shown on "Selected works".</p>
        </div>

        <!-- Card -->
        <div class="space-y-6">
          <h3 class="border-b border-border/50 pb-3 text-lg font-medium">Card</h3>
          <div class="max-w-sm">
            <article class="card group relative flex flex-col overflow-hidden rounded-lg border border-border/60 bg-card shadow-sm transition-shadow hover:shadow-md">
              <div class="card-media w-full overflow-hidden">
                <div class="aspect-video w-full overflow-hidden bg-muted flex items-center justify-center">
                  <svg class="h-16 w-16 text-muted-foreground/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
              </div>
              <div class="card-content flex flex-1 flex-col gap-3 p-6">
                <h2 class="text-xl font-semibold leading-tight">Case Study Title</h2>
                <p class="flex-1 text-sm leading-relaxed text-muted-foreground">A short description of the project. This is text-sm with relaxed line height and muted-foreground color.</p>
                <div class="flex flex-wrap gap-2">
                  <span class="rounded-full border border-border/60 px-2.5 py-0.5 text-xs text-muted-foreground">Research</span>
                  <span class="rounded-full border border-border/60 px-2.5 py-0.5 text-xs text-muted-foreground">UI Systems</span>
                </div>
                <a class="inline-flex items-center text-sm font-medium text-accent hover:underline" href="#">View project →</a>
              </div>
            </article>
          </div>
        </div>
        <!-- Active Filter Chip -->
        <div class="space-y-6">
          <h3 class="border-b border-border/50 pb-3 text-lg font-medium">Active Filter Chip</h3>
          <div class="flex flex-wrap items-center gap-3">
            <button class="flex items-center gap-1.5 rounded-full border border-accent/40 bg-accent/10 px-3 py-1 text-xs text-accent transition hover:bg-accent/20">
              <span>Photography</span>
              <span class="opacity-60">×</span>
            </button>
            <button class="flex items-center gap-1.5 rounded-full border border-accent/40 bg-accent/10 px-3 py-1 text-xs text-accent transition hover:bg-accent/20">
              <span>Motion Design</span>
              <span class="opacity-60">×</span>
            </button>
          </div>
          <p class="text-xs text-muted-foreground">Appears in the filter panel controls row when the currently active filter tag is hidden in the collapsed single-row view. Clicking the chip clears the filter and resets to "Show all".</p>
        </div>

        <!-- Modal -->
        <div class="space-y-6">
          <h3 class="border-b border-border/50 pb-3 text-lg font-medium">Modal</h3>
          <div class="max-w-md overflow-hidden rounded-xl border border-border bg-card shadow-lg">
            <div class="relative p-6">
              <button class="absolute right-3 top-3 flex h-8 w-8 items-center justify-center rounded-full border border-border/40 bg-card/80 text-muted-foreground transition-colors hover:bg-muted hover:text-foreground">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
              <h4 class="pr-8 text-xl font-semibold leading-tight">Modal Title</h4>
              <p class="mt-2 text-sm leading-relaxed text-muted-foreground">A summary line. On mobile this slides up as a bottom sheet; on desktop it appears as a centered panel.</p>
              <div class="mt-4 flex flex-wrap gap-2">
                <span class="rounded-full border border-border/60 px-2.5 py-0.5 text-xs text-muted-foreground">Tag</span>
                <span class="rounded-full border border-border/60 px-2.5 py-0.5 text-xs text-muted-foreground">Another tag</span>
              </div>
              <div class="mt-4 border-t border-border/40 pt-4">
                <p class="text-xs text-muted-foreground">Body content rendered via <code class="rounded-sm bg-muted px-1.5 py-0.5 font-mono">.card-modal-body</code> styles — see global.css.</p>
              </div>
            </div>
          </div>
          <p class="text-xs text-muted-foreground">Opens via <code class="rounded-sm bg-muted px-1.5 py-0.5 font-mono">data-modal-target="id"</code>. Animated with translate-y + opacity (200ms). ESC key and backdrop click both close. Focus is trapped to close button on open.</p>
        </div>

      </section>

      <!-- Page footer note -->
      <div class="border-t border-border/50 pb-4 pt-8">
        <p class="text-xs text-muted-foreground">
          Tokens are defined in <code class="rounded-sm bg-muted px-1.5 py-0.5 font-mono">src/styles/tokens.css</code> and mapped to Tailwind in <code class="rounded-sm bg-muted px-1.5 py-0.5 font-mono">tailwind.config.mjs</code>.
        </p>
      </div>

    </div>
  </main>
  <Footer />
</BaseLayout>
